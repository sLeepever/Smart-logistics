# =============================================================
# smartLogistics 环境变量配置
# 复制此文件为 .env 并填写真实值
# =============================================================

# PostgreSQL 密码
DB_PASSWORD=your_db_password

# JWT 签名密钥（Base64 编码的随机字符串，建议 32 字节以上）
JWT_SECRET=your_jwt_secret_base64

# 高德地图 Web 服务 API Key
AMAP_API_KEY=your_amap_key
