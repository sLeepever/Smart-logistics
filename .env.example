# ============================================================
# 环境变量示例文件（.env.example）
# 复制为 .env.local 并填入真实值，不要提交真实密钥到版本控制
# ============================================================

# 数据库密码（所有微服务共用同一个 PostgreSQL 用户）
DB_PASSWORD=your_postgres_password_here

# JWT 签名密钥（Base64 编码，长度至少 32 字节，生产环境随机生成）
JWT_SECRET=your_jwt_secret_base64_here

# 高德地图 Web 服务 API Key（dispatch-service 路线规划使用）
AMAP_API_KEY=your_amap_api_key_here
